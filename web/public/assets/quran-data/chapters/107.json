{"chapterNumber":107,"verses":[{"id":6198,"verse_key":"107:1","chapter_id":107,"verse_number":1,"juz_number":30,"hizb_number":60,"rub_el_hizb_number":240,"page_number":602,"text_uthmani":"أَرَءَيۡتَ ٱلَّذِي يُكَذِّبُ بِٱلدِّينِ ١","text_indopak":"اَرَءَيۡتَ الَّذِىۡ يُكَذِّبُ بِالدِّيۡنِؕ‏","text_uthmani_tajweed":"أَرَءَيْتَ <tajweed class=ham_wasl>ٱ</tajweed>لَّذِى يُكَذِّبُ بِ<tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>دّ<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>١</span>"},{"id":6199,"verse_key":"107:2","chapter_id":107,"verse_number":2,"juz_number":30,"hizb_number":60,"rub_el_hizb_number":240,"page_number":602,"text_uthmani":"فَذَٰلِكَ ٱلَّذِي يَدُعُّ ٱلۡيَتِيمَ ٢","text_indopak":"فَذٰلِكَ الَّذِىۡ يَدُعُّ الۡيَتِيۡمَۙ‏","text_uthmani_tajweed":"فَذ<tajweed class=madda_normal>َٲ</tajweed>لِكَ <tajweed class=ham_wasl>ٱ</tajweed>لَّذِى يَدُعُّ <tajweed class=ham_wasl>ٱ</tajweed>لْيَت<tajweed class=madda_permissible>ِي</tajweed>مَ <span class=end>٢</span>"},{"id":6200,"verse_key":"107:3","chapter_id":107,"verse_number":3,"juz_number":30,"hizb_number":60,"rub_el_hizb_number":240,"page_number":602,"text_uthmani":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ ٣","text_indopak":"وَ لَا يَحُضُّ عَلٰى طَعَامِ الۡمِسۡكِيۡنِؕ‏","text_uthmani_tajweed":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ <tajweed class=ham_wasl>ٱ</tajweed>لْمِسْك<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٣</span>"},{"id":6201,"verse_key":"107:4","chapter_id":107,"verse_number":4,"juz_number":30,"hizb_number":60,"rub_el_hizb_number":240,"page_number":602,"text_uthmani":"فَوَيۡلٞ لِّلۡمُصَلِّينَ ٤","text_indopak":"فَوَيۡلٌ لِّلۡمُصَلِّيۡنَۙ‏","text_uthmani_tajweed":"فَوَيْ<tajweed class=idgham_wo_ghunnah>لٌ ل</tajweed>ِّلْمُصَلّ<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٤</span>"},{"id":6202,"verse_key":"107:5","chapter_id":107,"verse_number":5,"juz_number":30,"hizb_number":60,"rub_el_hizb_number":240,"page_number":602,"text_uthmani":"ٱلَّذِينَ هُمۡ عَن صَلَاتِهِمۡ سَاهُونَ ٥","text_indopak":"الَّذِيۡنَ هُمۡ عَنۡ صَلَاتِهِمۡ سَاهُوۡنَۙ‏","text_uthmani_tajweed":"ٱلَّذِينَ هُمْ عَ<tajweed class=ikhafa>ن ص</tajweed>َلَاتِهِمْ سَاه<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٥</span>"},{"id":6203,"verse_key":"107:6","chapter_id":107,"verse_number":6,"juz_number":30,"hizb_number":60,"rub_el_hizb_number":240,"page_number":602,"text_uthmani":"ٱلَّذِينَ هُمۡ يُرَآءُونَ ٦","text_indopak":"الَّذِيۡنَ هُمۡ يُرَآءُوۡنَۙ‏","text_uthmani_tajweed":"ٱلَّذِينَ هُمْ يُر<tajweed class=madda_obligatory>َا</tajweed>ٓء<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٦</span>"},{"id":6204,"verse_key":"107:7","chapter_id":107,"verse_number":7,"juz_number":30,"hizb_number":60,"rub_el_hizb_number":240,"page_number":602,"text_uthmani":"وَيَمۡنَعُونَ ٱلۡمَاعُونَ ٧","text_indopak":"وَيَمۡنَعُوۡنَ الۡمَاعُوۡنَ‏","text_uthmani_tajweed":"وَيَمْنَعُونَ <tajweed class=ham_wasl>ٱ</tajweed>لْمَاع<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٧</span>"}],"source":"cache","cachedAt":"2026-07-04T02:22:17.121Z"}