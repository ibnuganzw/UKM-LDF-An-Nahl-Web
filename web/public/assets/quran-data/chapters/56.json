ass=ham_wasl>ٱ</tajweed>لْم<tajweed class=madda_obligatory>َا</tajweed>ٓءَ <tajweed class=ham_wasl>ٱ</tajweed>لَّذِى تَشْرَب<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٦٨</span>"},{"id":5048,"verse_key":"56:69","chapter_id":56,"verse_number":69,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"ءَأَنتُمۡ أَنزَلۡتُمُوهُ مِنَ ٱلۡمُزۡنِ أَمۡ نَحۡنُ ٱلۡمُنزِلُونَ ٦٩","text_indopak":"ءَاَنۡـتُمۡ اَنۡزَلۡـتُمُوۡهُ مِنَ الۡمُزۡنِ اَمۡ نَحۡنُ الۡمُنۡزِلُوۡنَ‏ ﻿﻿","text_uthmani_tajweed":"ءَأَ<tajweed class=ikhafa>نت</tajweed>ُمْ أَ<tajweed class=ikhafa>نز</tajweed>َلْتُمُوهُ مِنَ <tajweed class=ham_wasl>ٱ</tajweed>لْمُزْنِ أَمْ نَحْنُ <tajweed class=ham_wasl>ٱ</tajweed>لْمُ<tajweed class=ikhafa>نز</tajweed>ِل<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٦٩</span>"},{"id":5049,"verse_key":"56:70","chapter_id":56,"verse_number":70,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"لَوۡ نَشَآءُ جَعَلۡنَٰهُ أُجَاجٗا فَلَوۡلَا تَشۡكُرُونَ ٧٠","text_indopak":"لَوۡ نَشَآءُ جَعَلۡنٰهُ اُجَاجًا فَلَوۡلَا تَشۡكُرُوۡنَ‏","text_uthmani_tajweed":"لَوْ نَش<tajweed class=madda_obligatory>َا</tajweed>ٓءُ جَعَلْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُ أُجَا<tajweed class=ikhafa>جًا ف</tajweed>َلَوْلَا تَشْكُر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٧٠</span>"},{"id":5050,"verse_key":"56:71","chapter_id":56,"verse_number":71,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"أَفَرَءَيۡتُمُ ٱلنَّارَ ٱلَّتِي تُورُونَ ٧١","text_indopak":"اَفَرَءَيۡتُمُ النَّارَ الَّتِىۡ تُوۡرُوۡنَؕ‏","text_uthmani_tajweed":"أَفَرَءَيْتُمُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed><tajweed class=ghunnah>نّ</tajweed>َارَ <tajweed class=ham_wasl>ٱ</tajweed>لَّتِى تُور<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٧١</span>"},{"id":5051,"verse_key":"56:72","chapter_id":56,"verse_