"text_uthmani_tajweed":"لَأَكِلُونَ مِ<tajweed class=ikhafa>ن ش</tajweed>َجَ<tajweed class=idgham_ghunnah>رٍ م</tajweed>ِّ<tajweed class=ikhafa>ن ز</tajweed>َقّ<tajweed class=madda_permissible>ُو</tajweed>مٍ <span class=end>٥٢</span>"},{"id":5032,"verse_key":"56:53","chapter_id":56,"verse_number":53,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"فَمَالِـُٔونَ مِنۡهَا ٱلۡبُطُونَ ٥٣","text_indopak":"فَمٰلِــُٔوۡنَ مِنۡهَا الۡبُطُوۡنَ​ۚ‏","text_uthmani_tajweed":"فَمَالِــُٔونَ مِنْهَا <tajweed class=ham_wasl>ٱ</tajweed>لْبُط<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٥٣</span>"},{"id":5033,"verse_key":"56:54","chapter_id":56,"verse_number":54,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"فَشَٰرِبُونَ عَلَيۡهِ مِنَ ٱلۡحَمِيمِ ٥٤","text_indopak":"فَشٰرِبُوۡنَ عَلَيۡهِ مِنَ الۡحَمِيۡمِ​ۚ‏","text_uthmani_tajweed":"فَشَ<tajweed class=madda_normal>ـٰ</tajweed>رِبُونَ عَلَيْهِ مِنَ <tajweed class=ham_wasl>ٱ</tajweed>لْحَم<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٥٤</span>"},{"id":5034,"verse_key":"56:55","chapter_id":56,"verse_number":55,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"فَشَٰرِبُونَ شُرۡبَ ٱلۡهِيمِ ٥٥","text_indopak":"فَشٰرِبُوۡنَ شُرۡبَ الۡهِيۡمِؕ‏","text_uthmani_tajweed":"فَشَ<tajweed class=madda_normal>ـٰ</tajweed>رِبُونَ شُرْبَ <tajweed class=ham_wasl>ٱ</tajweed>لْه<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٥٥</span>"},{"id":5035,"verse_key":"56:56","chapter_id":56,"verse_number":56,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"هَٰذَا نُزُلُهُمۡ يَوۡمَ ٱلدِّينِ ٥٦","text_indopak":"هٰذَا نُزُلُهُمۡ يَوۡمَ الدِّيۡنِؕ‏","text_uthmani_tajweed":"هَ<tajweed class=madda_normal>ـٰ</tajweed>ذَا نُزُلُهُمْ يَوْمَ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>دّ<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٥٦</span>"},{"id":5036,"verse_key":"56:57","chapter_id":56,"verse_number":57,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"نَحۡنُ خَلَقۡنَٰكُمۡ فَلَوۡلَا تُصَدِّقُونَ ٥٧","text_indopak":"نَحۡنُ خَلَقۡنٰكُمۡ فَلَوۡلَا تُصَدِّقُوۡنَ‏","text_uthmani_tajweed":"نَحْنُ خَلَ<tajweed class=qalaqah>قْ</tajweed>نَ<tajweed class=madda_normal>ـٰ</tajweed>كُمْ فَلَوْلَا تُصَدِّق<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٥٧</span>"},{"id":5037,"verse_key":"56:58","chapter_id":56,"verse_number":58,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"أَفَرَءَيۡتُم مَّا تُمۡنُونَ ٥٨","text_indopak":"اَفَرَءَيۡتُمۡ مَّا تُمۡنُوۡنَؕ‏","text_uthmani_tajweed":"أَفَرَءَيْت<tajweed class=idgham_shafawi>ُم م</tajweed>َّا تُمْن<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٥٨</span>"},{"id":5038,"verse_key":"56:59","chapter_id":56,"verse_number":59,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"ءَأَنتُمۡ تَخۡلُقُونَهُۥٓ أَمۡ نَحۡنُ ٱلۡخَٰلِقُونَ ٥٩","text_indopak":"ءَاَنۡتُمۡ تَخۡلُقُوۡنَهٗۤ اَمۡ نَحۡنُ الۡخٰلِقُوۡنَ‏","text_uthmani_tajweed":"ءَأَ<tajweed class=ikhafa>نت</tajweed>ُمْ تَخْلُقُونَهُ<tajweed class=madda_obligatory>ۥٓ</tajweed> أَمْ نَحْنُ <tajweed class=ham_wasl>ٱ</tajweed>لْخَ<tajweed class=madda_normal>ـٰ</tajweed>لِق<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٥٩</span>"},{"id":5039,"verse_key":"56:60","chapter_id":56,"verse_number":60,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"نَحۡنُ قَدَّرۡنَا بَيۡنَكُمُ ٱلۡمَوۡتَ وَمَا نَحۡنُ بِمَسۡبُوقِينَ ٦٠","text_indopak":"نَحۡنُ قَدَّرۡنَا بَيۡنَكُمُ الۡمَوۡتَ وَمَا نَحۡنُ بِمَسۡبُوۡقِيۡنَۙ‏","text_uthmani_tajweed":"نَحْنُ قَدَّرْنَا بَيْنَكُمُ <tajweed class=ham_wasl>ٱ</tajweed>لْمَوْتَ وَمَا نَحْنُ بِمَسْبُوق<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٦٠</span>"},{"id":5040,"verse_key":"56:61","chapter_id":56,"verse_number":61,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"عَلَىٰٓ أَن نُّبَدِّلَ أَمۡثَٰلَكُمۡ وَنُنشِئَكُمۡ فِي مَا لَا تَعۡلَمُونَ ٦١","text_indopak":"عَلٰٓى اَنۡ نُّبَدِّلَ اَمۡثَالَـكُمۡ وَنُـنۡشِئَكُمۡ فِىۡ مَا لَا تَعۡلَمُوۡنَ‏ ﻿﻿","text_uthmani_tajweed":"عَلَ<tajweed class=madda_obligatory>ىٰٓ</tajweed> أ<tajweed class=idgham_ghunnah>َن ن</tajweed>ُّبَدِّلَ أَمْثَ<tajweed class=madda_normal>ـٰ</tajweed>لَكُمْ وَنُ<tajweed class=ikhafa>نش</tajweed>ِئَكُمْ فِى مَا لَا تَعْلَم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٦١</span>"},{"id":5041,"verse_key":"56:62","chapter_id":56,"verse_number":62,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"وَلَقَدۡ عَلِمۡتُمُ ٱلنَّشۡأَةَ ٱلۡأُولَىٰ فَلَوۡلَا تَذَكَّرُونَ ٦٢","text_indopak":"وَلَـقَدۡ عَلِمۡتُمُ النَّشۡاَةَ الۡاُوۡلٰى فَلَوۡلَا تَذَكَّرُوۡنَ‏","text_uthmani_tajweed":"وَلَقَ<tajweed class=qalaqah>دْ</tajweed> عَلِمْتُمُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed><tajweed class=ghunnah>نّ</tajweed>َشْأَةَ <tajweed class=ham_wasl>ٱ</tajweed>لْأُولَىٰ فَلَوْلَا تَذَكَّر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٦٢</span>"},{"id":5042,"verse_key":"56:63","chapter_id":56,"verse_number":63,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"أَفَرَءَيۡتُم مَّا تَحۡرُثُونَ ٦٣","text_indopak":"اَفَرَءَيۡتُمۡ مَّا تَحۡرُثُوۡنَؕ‏","text_uthmani_tajweed":"أَفَرَءَيْت<tajweed class=idgham_shafawi>ُم م</tajweed>َّا تَحْرُث<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٦٣</span>"},{"id":5043,"verse_key":"56:64","chapter_id":56,"verse_number":64,"juz_number":27,"hizb_number":54,"rub_el_hizb_number":214,"page_number":536,"text_uthmani":"ءَأَنتُمۡ تَزۡرَعُونَهُۥٓ أَمۡ نَحۡنُ ٱلزَّٰرِعُونَ ٦٤","text_indopak":"ءَاَنۡتُمۡ تَزۡرَعُوۡنَهٗۤ اَمۡ نَحۡنُ الزّ