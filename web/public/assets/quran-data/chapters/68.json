{"chapterNumber":68,"verses":[{"id":5272,"verse_key":"68:1","chapter_id":68,"verse_number":1,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"نٓۚ وَٱلۡقَلَمِ وَمَا يَسۡطُرُونَ ١","text_indopak":"نٓ​ وَالۡقَلَمِ وَمَا يَسۡطُرُوۡنَۙ‏","text_uthmani_tajweed":"<tajweed class=madda_necessary>نٓ</tajweed>‌ۚ وَ<tajweed class=ham_wasl>ٱ</tajweed>لْقَلَمِ وَمَا يَسْطُر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١</span>"},{"id":5273,"verse_key":"68:2","chapter_id":68,"verse_number":2,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"مَآ أَنتَ بِنِعۡمَةِ رَبِّكَ بِمَجۡنُونٖ ٢","text_indopak":"مَاۤ اَنۡتَ بِـنِعۡمَةِ رَبِّكَ بِمَجۡنُوۡنٍ​ۚ‏","text_uthmani_tajweed":"م<tajweed class=madda_obligatory>َآ</tajweed> أَ<tajweed class=ikhafa>نت</tajweed>َ بِنِعْمَةِ رَبِّكَ بِمَ<tajweed class=qalaqah>جْ</tajweed>ن<tajweed class=madda_permissible>ُو</tajweed>نٍ <span class=end>٢</span>"},{"id":5274,"verse_key":"68:3","chapter_id":68,"verse_number":3,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"وَإِنَّ لَكَ لَأَجۡرًا غَيۡرَ مَمۡنُونٖ ٣","text_indopak":"وَاِنَّ لَڪَ لَاَجۡرًا غَيۡرَ مَمۡنُوۡنٍ​ۚ‏","text_uthmani_tajweed":"وَإِ<tajweed class=ghunnah>نّ</tajweed>َ لَكَ لَأَ<tajweed class=qalaqah>جْ</tajweed>رًا غَيْرَ مَمْن<tajweed class=madda_permissible>ُو</tajweed>نٍ <span class=end>٣</span>"},{"id":5275,"verse_key":"68:4","chapter_id":68,"verse_number":4,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"وَإِنَّكَ لَعَلَىٰ خُلُقٍ عَظِيمٖ ٤","text_indopak":"وَاِنَّكَ لَعَلٰى خُلُقٍ عَظِيۡمٍ‏","text_uthmani_tajweed":"وَإِ<tajweed class=ghunnah>نّ</tajweed>َكَ لَعَلَىٰ خُلُقٍ عَظ<tajweed class=madda_permissible>ِي</tajweed>مٍ <span class=end>٤</span>"},{"id":5276,"verse_key":"68:5","chapter_id":68,"verse_number":5,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"فَسَتُبۡصِرُ وَيُبۡصِرُونَ ٥","text_indopak":"فَسَتُبۡصِرُ وَيُبۡصِرُوۡنَۙ‏","text_uthmani_tajweed":"فَسَتُ<tajweed class=qalaqah>بْ</tajweed>صِرُ وَيُ<tajweed class=qalaqah>بْ</tajweed>صِر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٥</span>"},{"id":5277,"verse_key":"68:6","chapter_id":68,"verse_number":6,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"بِأَييِّكُمُ ٱلۡمَفۡتُونُ ٦","text_indopak":"بِاَيِّٮكُمُ الۡمَفۡتُوۡنُ‏","text_uthmani_tajweed":"بِأَييِّكُمُ <tajweed class=ham_wasl>ٱ</tajweed>لْمَفْت<tajweed class=madda_permissible>ُو</tajweed>نُ <span class=end>٦</span>"},{"id":5278,"verse_key":"68:7","chapter_id":68,"verse_number":7,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"إِنَّ رَبَّكَ هُوَ أَعۡلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ وَهُوَ أَعۡلَمُ بِٱلۡمُهۡتَدِينَ ٧","text_indopak":"اِنَّ رَبَّكَ هُوَ اَعۡلَمُ بِمَنۡ ضَلَّ عَنۡ سَبِيۡلِهٖ وَهُوَ اَعۡلَمُ بِالۡمُهۡتَدِيۡنَ‏","text_uthmani_tajweed":"إِ<tajweed class=ghunnah>نّ</tajweed>َ رَبَّكَ هُوَ أَعْلَمُ بِمَ<tajweed class=ikhafa>ن ض</tajweed>َلَّ عَ<tajweed class=ikhafa>ن س</tajweed>َبِيلِه<tajweed class=madda_normal>ِۦ</tajweed> وَهُوَ أَعْلَمُ بِ<tajweed class=ham_wasl>ٱ</tajweed>لْمُهْتَد<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٧</span>"},{"id":5279,"verse_key":"68:8","chapter_id":68,"verse_number":8,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"فَلَا تُطِعِ ٱلۡمُكَذِّبِينَ ٨","text_indopak":"فَلَا تُطِعِ الۡمُكَذِّبِيۡنَ‏","text_uthmani_tajweed":"فَلَا تُطِعِ <tajweed class=ham_wasl>ٱ</tajweed>لْمُكَذِّب<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٨</span>"},{"id":5280,"verse_key":"68:9","chapter_id":68,"verse_number":9,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"وَدُّواْ لَوۡ تُدۡهِنُ فَيُدۡهِنُونَ ٩","text_indopak":"وَدُّوۡا لَوۡ تُدۡهِنُ فَيُدۡهِنُوۡنَ‏","text_uthmani_tajweed":"وَدُّو<tajweed class=slnt>اْ</tajweed> لَوْ تُ<tajweed class=qalaqah>دْ</tajweed>هِنُ فَيُ<tajweed class=qalaqah>دْ</tajweed>هِن<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٩</span>"},{"id":5281,"verse_key":"68:10","chapter_id":68,"verse_number":10,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"وَلَا تُطِعۡ كُلَّ حَلَّافٖ مَّهِينٍ ١٠","text_indopak":"وَلَا تُطِعۡ كُلَّ حَلَّافٍ مَّهِيۡنٍۙ‏","text_uthmani_tajweed":"وَلَا تُطِعْ كُلَّ حَلَّا<tajweed class=idgham_ghunnah>فٍ م</tajweed>َّه<tajweed class=madda_permissible>ِي</tajweed>نٍ <span class=end>١٠</span>"},{"id":5282,"verse_key":"68:11","chapter_id":68,"verse_number":11,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"هَمَّازٖ مَّشَّآءِۭ بِنَمِيمٖ ١١","text_indopak":"هَمَّازٍ مَّشَّآءٍۢ بِنَمِيۡمٍۙ‏","text_uthmani_tajweed":"هَ<tajweed class=ghunnah>مّ</tajweed>َا<tajweed class=idgham_ghunnah>زٍ م</tajweed>َّشّ<tajweed class=madda_obligatory>َا</tajweed>ٓ<tajweed class=iqlab>ءِۭ ب</tajweed>ِنَم<tajweed class=madda_permissible>ِي</tajweed>مٍ <span class=end>١١</span>"},{"id":5283,"verse_key":"68:12","chapter_id":68,"verse_number":12,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"مَّنَّاعٖ لِّلۡخَيۡرِ مُعۡتَدٍ أَثِيمٍ ١٢","text_indopak":"مَّنَّاعٍ لِّلۡخَيۡرِ مُعۡتَدٍ اَثِيۡمٍۙ‏","text_uthmani_tajweed":"مَّ<tajweed class=ghunnah>نّ</tajweed>َا<tajweed class=idgham_wo_ghunnah>عٍ ل</tajweed>ِّلْخَيْرِ مُعْتَدٍ أَث<tajweed class=madda_permissible>ِي</tajweed>مٍ <span class=end>١٢</span>"},{"id":5284,"verse_key":"68:13","chapter_id":68,"verse_number":13,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"عُتُلِّۭ بَعۡدَ ذَٰلِكَ زَنِيمٍ ١٣","text_indopak":"عُتُلٍّ ۢ بَعۡدَ ذٰلِكَ زَنِيۡمٍۙ‏","text_uthmani_tajweed":"عُتُل<tajweed class=iqlab>ِّۭ ب</tajweed>َعْدَ ذ<tajweed class=madda_normal>َٲ</tajweed>لِكَ زَن<tajweed class=madda_permissible>ِي</tajweed>مٍ <span class=end>١٣</span>"},{"id":5285,"verse_key":"68:14","chapter_id":68,"verse_number":14,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"أَن كَانَ ذَا مَالٖ وَبَنِينَ ١٤","text_indopak":"اَنۡ كَانَ ذَا مَالٍ وَّبَنِيۡنَؕ‏","text_uthmani_tajweed":"أَ<tajweed class=ikhafa>ن ك</tajweed>َانَ ذَا مَا<tajweed class=idgham_ghunnah>لٍ و</tajweed>َبَن<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٤</span>"},{"id":5286,"verse_key":"68:15","chapter_id":68,"verse_number":15,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":564,"text_uthmani":"إِذَا تُتۡلَىٰ عَلَيۡهِ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ ٱلۡأَوَّلِينَ ١٥","text_indopak":"اِذَا تُتۡلٰى عَلَيۡهِ اٰيٰتُنَا قَالَ اَسَاطِيۡرُ الۡاَوَّلِيۡنَ‏","text_uthmani_tajweed":"إِذَا تُتْلَىٰ عَلَيْهِ ءَايَ<tajweed class=madda_normal>ـٰ</tajweed>تُنَا قَالَ أَسَ<tajweed class=madda_normal>ـٰ</tajweed>طِيرُ <tajweed class=ham_wasl>ٱ</tajweed>لْأَوَّل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٥</span>"},{"id":5287,"verse_key":"68:16","chapter_id":68,"verse_number":16,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"سَنَسِمُهُۥ عَلَى ٱلۡخُرۡطُومِ ١٦","text_indopak":"سَنَسِمُهٗ عَلَى الۡخُـرۡطُوۡمِ‏","text_uthmani_tajweed":"سَنَسِمُهُ<tajweed class=madda_normal>ۥ</tajweed> عَلَى <tajweed class=ham_wasl>ٱ</tajweed>لْخُرْط<tajweed class=madda_permissible>ُو</tajweed>مِ <span class=end>١٦</span>"},{"id":5288,"verse_key":"68:17","chapter_id":68,"verse_number":17,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"إِنَّا بَلَوۡنَٰهُمۡ كَمَا بَلَوۡنَآ أَصۡحَٰبَ ٱلۡجَنَّةِ إِذۡ أَقۡسَمُواْ لَيَصۡرِمُنَّهَا مُصۡبِحِينَ ١٧","text_indopak":"اِنَّا بَلَوۡنٰهُمۡ كَمَا بَلَوۡنَاۤ اَصۡحٰبَ الۡجَـنَّةِ​ ۚ اِذۡ اَقۡسَمُوۡا لَيَصۡرِمُنَّهَا مُصۡبِحِيۡنَۙ‏","text_uthmani_tajweed":"إِ<tajweed class=ghunnah>نّ</tajweed>َا بَلَوْنَ<tajweed class=madda_normal>ـٰ</tajweed>هُمْ كَمَا بَلَوْن<tajweed class=madda_obligatory>َآ</tajweed> أَصْحَ<tajweed class=madda_normal>ـٰ</tajweed>بَ <tajweed class=ham_wasl>ٱ</tajweed>لْجَ<tajweed class=ghunnah>نّ</tajweed>َةِ إِذْ أَ<tajweed class=qalaqah>قْ</tajweed>سَمُو<tajweed class=slnt>اْ</tajweed> لَيَصْرِمُ<tajweed class=ghunnah>نّ</tajweed>َهَا مُصْبِح<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١٧</span>"},{"id":5289,"verse_key":"68:18","chapter_id":68,"verse_number":18,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"وَلَا يَسۡتَثۡنُونَ ١٨","text_indopak":"وَلَا يَسۡتَثۡنُوۡنَ‏","text_uthmani_tajweed":"وَلَا يَسْتَثْن<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٨</span>"},{"id":5290,"verse_key":"68:19","chapter_id":68,"verse_number":19,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"فَطَافَ عَلَيۡهَا طَآئِفٞ مِّن رَّبِّكَ وَهُمۡ نَآئِمُونَ ١٩","text_indopak":"فَطَافَ عَلَيۡهَا طَآٮِٕفٌ مِّنۡ رَّبِّكَ وَهُمۡ نَآٮِٕمُوۡنَ‏","text_uthmani_tajweed":"فَطَافَ عَلَيْهَا ط<tajweed class=madda_obligatory>َا</tajweed>ٓئِ<tajweed class=idgham_ghunnah>فٌ م</tajweed>ّ<tajweed class=idgham_wo_ghunnah>ِن ر</tajweed>َّبِّكَ وَهُمْ ن<tajweed class=madda_obligatory>َا</tajweed>ٓئِم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>١٩</span>"},{"id":5291,"verse_key":"68:20","chapter_id":68,"verse_number":20,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"فَأَصۡبَحَتۡ كَٱلصَّرِيمِ ٢٠","text_indopak":"فَاَصۡبَحَتۡ كَالصَّرِيۡمِۙ‏","text_uthmani_tajweed":"فَأَصْبَحَتْ كَ<tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>صَّر<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٢٠</span>"},{"id":5292,"verse_key":"68:21","chapter_id":68,"verse_number":21,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"فَتَنَادَوۡاْ مُصۡبِحِينَ ٢١","text_indopak":"فَتَـنَادَوۡا مُصۡبِحِيۡنَۙ‏","text_uthmani_tajweed":"فَتَنَادَوْ<tajweed class=slnt>اْ</tajweed> مُصْبِح<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٢١</span>"},{"id":5293,"verse_key":"68:22","chapter_id":68,"verse_number":22,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"أَنِ ٱغۡدُواْ عَلَىٰ حَرۡثِكُمۡ إِن كُنتُمۡ صَٰرِمِينَ ٢٢","text_indopak":"اَنِ اغۡدُوۡا عَلٰى حَرۡثِكُمۡ اِنۡ كُنۡتُمۡ صٰرِمِيۡنَ‏","text_uthmani_tajweed":"أَنِ <tajweed class=ham_wasl>ٱ</tajweed>غْدُو<tajweed class=slnt>اْ</tajweed> عَلَىٰ حَرْثِكُمْ إِ<tajweed class=ikhafa>ن ك</tajweed>ُ<tajweed class=ikhafa>نت</tajweed>ُمْ صَ<tajweed class=madda_normal>ـٰ</tajweed>رِم<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٢٢</span>"},{"id":5294,"verse_key":"68:23","chapter_id":68,"verse_number":23,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"فَٱنطَلَقُواْ وَهُمۡ يَتَخَٰفَتُونَ ٢٣","text_indopak":"فَانۡطَلَقُوۡا وَهُمۡ يَتَخَافَتُوۡنَۙ‏","text_uthmani_tajweed":"فَ<tajweed class=ham_wasl>ٱ</tajweed><tajweed class=ikhafa>نط</tajweed>َلَقُو<tajweed class=slnt>اْ</tajweed> وَهُمْ يَتَخَ<tajweed class=madda_normal>ـٰ</tajweed>فَت<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٣</span>"},{"id":5295,"verse_key":"68:24","chapter_id":68,"verse_number":24,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"أَن لَّا يَدۡخُلَنَّهَا ٱلۡيَوۡمَ عَلَيۡكُم مِّسۡكِينٞ ٢٤","text_indopak":"اَنۡ لَّا يَدۡخُلَنَّهَا الۡيَوۡمَ عَلَيۡكُمۡ مِّسۡكِيۡنٌۙ‏","text_uthmani_tajweed":"أ<tajweed class=idgham_wo_ghunnah>َن ل</tajweed>َّا يَ<tajweed class=qalaqah>دْ</tajweed>خُلَ<tajweed class=ghunnah>نّ</tajweed>َهَا <tajweed class=ham_wasl>ٱ</tajweed>لْيَوْمَ عَلَيْك<tajweed class=idgham_shafawi>ُم م</tajweed>ِّسْك<tajweed class=madda_permissible>ِي</tajweed>نٌ <span class=end>٢٤</span>"},{"id":5296,"verse_key":"68:25","chapter_id":68,"verse_number":25,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"وَغَدَوۡاْ عَلَىٰ حَرۡدٖ قَٰدِرِينَ ٢٥","text_indopak":"وَّغَدَوۡا عَلٰى حَرۡدٍ قٰدِرِيۡنَ‏","text_uthmani_tajweed":"وَغَدَوْ<tajweed class=slnt>اْ</tajweed> عَلَىٰ حَرْ<tajweed class=ikhafa>دٍ ق</tajweed>َ<tajweed class=madda_normal>ـٰ</tajweed>دِر<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٢٥</span>"},{"id":5297,"verse_key":"68:26","chapter_id":68,"verse_number":26,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"فَلَمَّا رَأَوۡهَا قَالُوٓاْ إِنَّا لَضَآلُّونَ ٢٦","text_indopak":"فَلَمَّا رَاَوۡهَا قَالُوۡۤا اِنَّا لَـضَآلُّوۡنَۙ‏","text_uthmani_tajweed":"فَلَ<tajweed class=ghunnah>مّ</tajweed>َا رَأَوْهَا قَال<tajweed class=madda_obligatory>ُوٓ</tajweed><tajweed class=slnt>اْ</tajweed> إِ<tajweed class=ghunnah>نّ</tajweed>َا لَض<tajweed class=madda_necessary>َا</tajweed>ٓلّ<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٦</span>"},{"id":5298,"verse_key":"68:27","chapter_id":68,"verse_number":27,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"بَلۡ نَحۡنُ مَحۡرُومُونَ ٢٧","text_indopak":"بَلۡ نَحۡنُ مَحۡرُوۡمُوۡنَ‏","text_uthmani_tajweed":"بَلْ نَحْنُ مَحْرُوم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٧</span>"},{"id":5299,"verse_key":"68:28","chapter_id":68,"verse_number":28,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"قَالَ أَوۡسَطُهُمۡ أَلَمۡ أَقُل لَّكُمۡ لَوۡلَا تُسَبِّحُونَ ٢٨","text_indopak":"قَالَ اَوۡسَطُهُمۡ اَلَمۡ اَقُلۡ لَّكُمۡ لَوۡلَا تُسَبِّحُوۡنَ‏","text_uthmani_tajweed":"قَالَ أَوْسَطُهُمْ أَلَمْ أَقُل لَّكُمْ لَوْلَا تُسَبِّح<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٨</span>"},{"id":5300,"verse_key":"68:29","chapter_id":68,"verse_number":29,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"قَالُواْ سُبۡحَٰنَ رَبِّنَآ إِنَّا كُنَّا ظَٰلِمِينَ ٢٩","text_indopak":"قَالُوۡا سُبۡحٰنَ رَبِّنَاۤ اِنَّا كُنَّا ظٰلِمِيۡنَ‏","text_uthmani_tajweed":"قَالُو<tajweed class=slnt>اْ</tajweed> سُ<tajweed class=qalaqah>بْ</tajweed>حَ<tajweed class=madda_normal>ـٰ</tajweed>نَ رَبِّن<tajweed class=madda_obligatory>َآ</tajweed> إِ<tajweed class=ghunnah>نّ</tajweed>َا كُ<tajweed class=ghunnah>نّ</tajweed>َا ظَ<tajweed class=madda_normal>ـٰ</tajweed>لِم<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٢٩</span>"},{"id":5301,"verse_key":"68:30","chapter_id":68,"verse_number":30,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"فَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضٖ يَتَلَٰوَمُونَ ٣٠","text_indopak":"فَاَقۡبَلَ بَعۡضُهُمۡ عَلٰى بَعۡضٍ يَّتَلَاوَمُوۡنَ‏","text_uthmani_tajweed":"فَأَ<tajweed class=qalaqah>قْ</tajweed>بَلَ بَعْضُهُمْ عَلَىٰ بَعْ<tajweed class=idgham_ghunnah>ضٍ ي</tajweed>َتَلَ<tajweed class=madda_normal>ـٰ</tajweed>وَم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٠</span>"},{"id":5302,"verse_key":"68:31","chapter_id":68,"verse_number":31,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"قَالُواْ يَٰوَيۡلَنَآ إِنَّا كُنَّا طَٰغِينَ ٣١","text_indopak":"قَالُوۡا يٰوَيۡلَنَاۤ اِنَّا كُنَّا طٰغِيۡنَ‏","text_uthmani_tajweed":"قَالُو<tajweed class=slnt>اْ</tajweed> يَ<tajweed class=madda_normal>ـٰ</tajweed>وَيْلَن<tajweed class=madda_obligatory>َآ</tajweed> إِ<tajweed class=ghunnah>نّ</tajweed>َا كُ<tajweed class=ghunnah>نّ</tajweed>َا طَ<tajweed class=madda_normal>ـٰ</tajweed>غ<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣١</span>"},{"id":5303,"verse_key":"68:32","chapter_id":68,"verse_number":32,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"عَسَىٰ رَبُّنَآ أَن يُبۡدِلَنَا خَيۡرٗا مِّنۡهَآ إِنَّآ إِلَىٰ رَبِّنَا رَٰغِبُونَ ٣٢","text_indopak":"عَسٰى رَبُّنَاۤ اَنۡ يُّبۡدِلَـنَا خَيۡرًا مِّنۡهَاۤ اِنَّاۤ اِلٰى رَبِّنَا رٰغِبُوۡنَ‏","text_uthmani_tajweed":"عَسَىٰ رَبُّن<tajweed class=madda_obligatory>َآ</tajweed> أ<tajweed class=idgham_ghunnah>َن ي</tajweed>ُ<tajweed class=qalaqah>بْ</tajweed>دِلَنَا خَيْ<tajweed class=idgham_ghunnah>رًا م</tajweed>ِّنْه<tajweed class=madda_obligatory>َآ</tajweed> إِ<tajweed class=ghunnah>نّ</tajweed><tajweed class=madda_obligatory>َآ</tajweed> إِلَىٰ رَبِّنَا ر<tajweed class=madda_normal>َٲ</tajweed>غِب<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٢</span>"},{"id":5304,"verse_key":"68:33","chapter_id":68,"verse_number":33,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"كَذَٰلِكَ ٱلۡعَذَابُۖ وَلَعَذَابُ ٱلۡأٓخِرَةِ أَكۡبَرُۚ لَوۡ كَانُواْ يَعۡلَمُونَ ٣٣","text_indopak":"كَذٰلِكَ الۡعَذَابُ​ؕ وَلَعَذَابُ الۡاٰخِرَةِ اَكۡبَرُ ​ۘ لَوۡ كَانُوۡا يَعۡلَمُوۡنَ‏ ﻿﻿","text_uthmani_tajweed":"كَذ<tajweed class=madda_normal>َٲ</tajweed>لِكَ <tajweed class=ham_wasl>ٱ</tajweed>لْعَذَابُ‌ۖ وَلَعَذَابُ <tajweed class=ham_wasl>ٱ</tajweed>لْأَخِرَةِ أَكْبَرُ‌ۚ لَوْ كَانُو<tajweed class=slnt>اْ</tajweed> يَعْلَم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٣</span>"},{"id":5305,"verse_key":"68:34","chapter_id":68,"verse_number":34,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"إِنَّ لِلۡمُتَّقِينَ عِندَ رَبِّهِمۡ جَنَّٰتِ ٱلنَّعِيمِ ٣٤","text_indopak":"اِنَّ لِلۡمُتَّقِيۡنَ عِنۡدَ رَبِّهِمۡ جَنّٰتِ النَّعِيۡمِ‏","text_uthmani_tajweed":"إِ<tajweed class=ghunnah>نّ</tajweed>َ لِلْمُتَّقِينَ عِ<tajweed class=ikhafa>ند</tajweed>َ رَبِّهِمْ جَ<tajweed class=ghunnah>نّ</tajweed>َ<tajweed class=madda_normal>ـٰ</tajweed>تِ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed><tajweed class=ghunnah>نّ</tajweed>َع<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٣٤</span>"},{"id":5306,"verse_key":"68:35","chapter_id":68,"verse_number":35,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"أَفَنَجۡعَلُ ٱلۡمُسۡلِمِينَ كَٱلۡمُجۡرِمِينَ ٣٥","text_indopak":"اَفَنَجۡعَلُ الۡمُسۡلِمِيۡنَ كَالۡمُجۡرِمِيۡنَؕ‏","text_uthmani_tajweed":"أَفَنَ<tajweed class=qalaqah>جْ</tajweed>عَلُ <tajweed class=ham_wasl>ٱ</tajweed>لْمُسْلِمِينَ كَ<tajweed class=ham_wasl>ٱ</tajweed>لْمُ<tajweed class=qalaqah>جْ</tajweed>رِم<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٥</span>"},{"id":5307,"verse_key":"68:36","chapter_id":68,"verse_number":36,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"مَا لَكُمۡ كَيۡفَ تَحۡكُمُونَ ٣٦","text_indopak":"مَا لَـكُمۡ كَيۡفَ تَحۡكُمُوۡنَ​ۚ‏","text_uthmani_tajweed":"مَا لَكُمْ كَيْفَ تَحْكُم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٦</span>"},{"id":5308,"verse_key":"68:37","chapter_id":68,"verse_number":37,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"أَمۡ لَكُمۡ كِتَٰبٞ فِيهِ تَدۡرُسُونَ ٣٧","text_indopak":"اَمۡ لَـكُمۡ كِتٰبٌ فِيۡهِ تَدۡرُسُوۡنَۙ‏","text_uthmani_tajweed":"أَمْ لَكُمْ كِتَ<tajweed class=madda_normal>ـٰ</tajweed><tajweed class=ikhafa>بٌ ف</tajweed>ِيهِ تَ<tajweed class=qalaqah>دْ</tajweed>رُس<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٧</span>"},{"id":5309,"verse_key":"68:38","chapter_id":68,"verse_number":38,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"إِنَّ لَكُمۡ فِيهِ لَمَا تَخَيَّرُونَ ٣٨","text_indopak":"اِنَّ لَـكُمۡ فِيۡهِ لَمَا تَخَيَّرُوۡنَ​ۚ‏","text_uthmani_tajweed":"إِ<tajweed class=ghunnah>نّ</tajweed>َ لَكُمْ فِيهِ لَمَا تَخَيَّر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٨</span>"},{"id":5310,"verse_key":"68:39","chapter_id":68,"verse_number":39,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":226,"page_number":565,"text_uthmani":"أَمۡ لَكُمۡ أَيۡمَٰنٌ عَلَيۡنَا بَٰلِغَةٌ إِلَىٰ يَوۡمِ ٱلۡقِيَٰمَةِ إِنَّ لَكُ