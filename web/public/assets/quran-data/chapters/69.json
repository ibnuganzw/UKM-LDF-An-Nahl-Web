":227,"page_number":567,"text_uthmani":"وَٱنشَقَّتِ ٱلسَّمَآءُ فَهِيَ يَوۡمَئِذٖ وَاهِيَةٞ ١٦","text_indopak":"وَانْشَقَّتِ السَّمَآءُ فَهِىَ يَوۡمَٮِٕذٍ وَّاهِيَةٌ ۙ‏","text_uthmani_tajweed":"وَ<tajweed class=ham_wasl>ٱ</tajweed><tajweed class=ikhafa>نش</tajweed>َقَّتِ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>سَّم<tajweed class=madda_obligatory>َا</tajweed>ٓءُ فَهِىَ يَوْمَئِ<tajweed class=idgham_ghunnah>ذٍ و</tajweed>َاهِيَةٌ <span class=end>١٦</span>"},{"id":5340,"verse_key":"69:17","chapter_id":69,"verse_number":17,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"وَٱلۡمَلَكُ عَلَىٰٓ أَرۡجَآئِهَاۚ وَيَحۡمِلُ عَرۡشَ رَبِّكَ فَوۡقَهُمۡ يَوۡمَئِذٖ ثَمَٰنِيَةٞ ١٧","text_indopak":"وَّالۡمَلَكُ عَلٰٓى اَرۡجَآٮِٕهَا ​ؕ وَيَحۡمِلُ عَرۡشَ رَبِّكَ فَوۡقَهُمۡ يَوۡمَٮِٕذٍ ثَمٰنِيَةٌ ؕ‏","text_uthmani_tajweed":"وَ<tajweed class=ham_wasl>ٱ</tajweed>لْمَلَكُ عَلَ<tajweed class=madda_obligatory>ىٰٓ</tajweed> أَرْج<tajweed class=madda_obligatory>َا</tajweed>ٓئِهَا‌ۚ وَيَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِ<tajweed class=ikhafa>ذٍ ث</tajweed>َمَ<tajweed class=madda_normal>ـٰ</tajweed>نِيَةٌ <span class=end>١٧</span>"},{"id":5341,"verse_key":"69:18","chapter_id":69,"verse_number":18,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"يَوۡمَئِذٖ تُعۡرَضُونَ لَا تَخۡفَىٰ مِنكُمۡ خَافِيَةٞ ١٨","text_indopak":"يَوۡمَٮِٕذٍ تُعۡرَضُوۡنَ لَا تَخۡفٰى مِنۡكُمۡ خَافِيَةٌ‏","text_uthmani_tajweed":"يَوْمَئِ<tajweed class=ikhafa>ذٍ ت</tajweed>ُعْرَضُونَ لَا تَخْفَىٰ مِ<tajweed class=ikhafa>نك</tajweed>ُمْ خَافِيَةٌ <span class=end>١٨</span>"},{"id":5342,"verse_key":"69:19","chapter_id":69,"verse_number":19,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"فَأَمَّا مَنۡ أُوتِيَ كِتَٰبَهُۥ بِيَمِينِهِۦ فَيَقُولُ هَآؤُمُ ٱقۡرَءُواْ كِتَٰبِيَهۡ ١٩","text_indopak":"فَاَمَّا مَنۡ اُوۡتِىَ كِتٰبَهٗ بِيَمِيۡنِهٖۙ فَيَقُوۡلُ هَآؤُمُ اقۡرَءُوۡا كِتٰبِيَهۡ​ۚ‏","text_uthmani_tajweed":"فَأَ<tajweed class=ghunnah>مّ</tajweed>َا مَنْ أُوتِىَ كِتَ<tajweed class=madda_normal>ـٰ</tajweed>بَهُ<tajweed class=madda_normal>ۥ</tajweed> بِيَمِينِه<tajweed class=madda_normal>ِۦ</tajweed> فَيَقُولُ ه<tajweed class=madda_obligatory>َا</tajweed>ٓؤُمُ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=qalaqah>قْ</tajweed>رَءُو<tajweed class=slnt>اْ</tajweed> كِتَ<tajweed class=madda_normal>ـٰ</tajweed>بِيَهْ <span class=end>١٩</span>"},{"id":5343,"verse_key":"69:20","chapter_id":69,"verse_number":20,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"إِنِّي ظَنَنتُ أَنِّي مُلَٰقٍ حِسَابِيَهۡ ٢٠","text_indopak":"اِنِّىۡ ظَنَنۡتُ اَنِّىۡ مُلٰقٍ حِسَابِيَهۡ​ۚ‏","text_uthmani_tajweed":"إِ<tajweed class=ghunnah>نّ</tajweed>ِى ظَنَ<tajweed class=ikhafa>نت</tajweed>ُ أَ<tajweed class=ghunnah>نّ</tajweed>ِى مُلَ<tajweed class=madda_normal>ـٰ</tajweed>قٍ حِسَابِيَهْ <span class=end>٢٠</span>"},{"id":5344,"verse_key":"69:21","chapter_id":69,"verse_number":21,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"فَهُوَ فِي عِيشَةٖ رَّاضِيَةٖ ٢١","text_indopak":"فَهُوَ فِىۡ عِيۡشَةٍ رَّاضِيَةٍۙ‏","text_uthmani_tajweed":"فَهُوَ فِى عِيشَ<tajweed class=idgham_wo_ghunnah>ةٍ ر</tajweed>َّاضِيَةٍ <span class=end>٢١</span>"},{"id":5345,"verse_key":"69:22","chapter_id":69,"verse_number":22,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"فِي جَنَّةٍ عَالِيَةٖ ٢٢","text_indopak":"فِىۡ جَنَّةٍ عَالِيَةٍۙ‏","text_uthmani_tajweed":"فِى جَ<tajweed class=ghunnah>نّ</tajweed>َةٍ عَالِيَةٍ <span class=end>٢٢</span>"},{"id":5346,"verse_key":"69:23","chapter_id":69,"verse_number":23,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"قُطُوفُهَا دَانِيَةٞ ٢٣","text_indopak":"قُطُوۡفُهَا دَانِيَةٌ‏","text_uthmani_tajweed":"قُطُوفُهَا دَانِيَةٌ <span class=end>٢٣</span>"},{"id":5347,"verse_key":"69:24","chapter_id":69,"verse_number":24,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"كُلُواْ وَٱشۡرَبُواْ هَنِيٓـَٔۢا بِمَآ أَسۡلَفۡتُمۡ فِي ٱلۡأَيَّامِ ٱلۡخَالِيَةِ ٢٤","text_indopak":"كُلُوۡا وَاشۡرَبُوۡا هَنِيۡٓـــًٔا ۢ بِمَاۤ اَسۡلَفۡتُمۡ فِى الۡاَيَّامِ الۡخَـالِيَةِ‏ ﻿﻿","text_uthmani_tajweed":"كُلُو<tajweed class=slnt>اْ</tajweed> وَ<tajweed class=ham_wasl>ٱ</tajweed>شْرَبُو<tajweed class=slnt>اْ</tajweed> هَنِ<tajweed class=madda_obligatory>يٓـ</tajweed>ـ<tajweed class=iqlab>ـَٔۢا ب</tajweed>ِم<tajweed class=madda_obligatory>َآ</tajweed> أَسْلَفْتُمْ فِى <tajweed class=ham_wasl>ٱ</tajweed>لْأَيَّامِ <tajweed class=ham_wasl>ٱ</tajweed>لْخَالِيَةِ <span class=end>٢٤</span>"},{"id":5348,"verse_key":"69:25","chapter_id":69,"verse_number":25,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"وَأَمَّا مَنۡ أُوتِيَ كِتَٰبَهُۥ بِشِمَالِهِۦ فَيَقُولُ يَٰلَيۡتَنِي لَمۡ أُوتَ كِتَٰبِيَهۡ ٢٥","text_indopak":"وَاَمَّا مَنۡ اُوۡتِىَ كِتٰبَهٗ بِشِمَالِهٖ  ۙ فَيَقُوۡلُ يٰلَيۡتَنِىۡ لَمۡ اُوۡتَ كِتٰبِيَهۡ​ۚ‏","text_uthmani_tajweed":"وَأَ<tajweed class=ghunnah>مّ</tajweed>َا مَنْ أُوتِىَ كِتَ<tajweed class=madda_normal>ـٰ</tajweed>بَهُ<tajweed class=madda_normal>ۥ</tajweed> بِشِمَالِه<tajweed class=madda_normal>ِۦ</tajweed> فَيَقُولُ يَ<tajweed class=madda_normal>ـٰ</tajweed>لَيْتَنِى لَمْ أُوتَ كِتَ<tajweed class=madda_normal>ـٰ</tajweed>بِيَهْ <span class=end>٢٥</span>"},{"id":5349,"verse_key":"69:26","chapter_id":69,"verse_number":26,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"وَلَمۡ أَدۡرِ مَا حِسَابِيَهۡ ٢٦","text_indopak":"وَلَمۡ اَدۡرِ مَا حِسَابِيَهۡ​ۚ‏","text_uthmani_tajweed":"وَلَمْ أَ<tajweed class=qalaqah>دْ</tajweed>رِ مَا حِسَابِيَهْ <span class=end>٢٦</span>"},{"id":5350,"verse_key":"69:27","chapter_id":69,"verse_number":27,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"يَٰلَيۡتَهَا كَانَتِ ٱلۡقَاضِيَةَ ٢٧","text_indopak":"يٰلَيۡتَهَا كَانَتِ الۡقَاضِيَةَ​ ۚ‏","text_uthmani_tajweed":"يَ<tajweed class=madda_normal>ـٰ</tajweed>لَيْتَهَا كَانَتِ <tajweed class=ham_wasl>ٱ</tajweed>لْقَاضِيَةَ <span class=end>٢٧</span>"},{"id":5351,"verse_key":"69:28","chapter_id":69,"verse_number":28,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"مَآ أَغۡنَىٰ عَنِّي مَالِيَهۡۜ ٢٨","text_indopak":"مَاۤ اَغۡنٰى عَنِّىۡ مَالِيَهۡۚ‏","text_uthmani_tajweed":"م<tajweed class=madda_obligatory>َآ</tajweed> أَغْنَىٰ عَ<tajweed class=ghunnah>نّ</tajweed>ِى مَالِيَهْۜ <span class=end>٢٨</span>"},{"id":5352,"verse_key":"69:29","chapter_id":69,"verse_number":29,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"هَلَكَ عَنِّي سُلۡطَٰنِيَهۡ ٢٩","text_indopak":"هَلَكَ عَنِّىۡ سُلۡطٰنِيَهۡ​ۚ‏","text_uthmani_tajweed":"هَلَكَ عَ<tajweed class=ghunnah>نّ</tajweed>ِى سُلْطَ<tajweed class=madda_normal>ـٰ</tajweed>نِيَهْ <span class=end>٢٩</span>"},{"id":5353,"verse_key":"69:30","chapter_id":69,"verse_number":30,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"خُذُوهُ فَغُلُّوهُ ٣٠","text_indopak":"خُذُوۡهُ فَغُلُّوۡهُ ۙ‏","text_uthmani_tajweed":"خُذُوهُ فَغُلّ<tajweed class=madda_permissible>ُو</tajweed>هُ <span class=end>٣٠</span>"},{"id":5354,"verse_key":"69:31","chapter_id":69,"verse_number":31,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"ثُمَّ ٱلۡجَحِيمَ صَلُّوهُ ٣١","text_indopak":"ثُمَّ الۡجَحِيۡمَ صَلُّوۡهُ ۙ‏","text_uthmani_tajweed":"ثُ<tajweed class=ghunnah>مّ</tajweed>َ <tajweed class=ham_wasl>ٱ</tajweed>لْجَحِيمَ صَلّ<tajweed class=madda_permissible>ُو</tajweed>هُ <span class=end>٣١</span>"},{"id":5355,"verse_key":"69:32","chapter_id":69,"verse_number":32,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"ثُمَّ فِي سِلۡسِلَةٖ ذَرۡعُهَا سَبۡعُونَ ذِرَاعٗا فَٱسۡلُكُوهُ ٣٢","text_indopak":"ثُمَّ فِىۡ سِلۡسِلَةٍ ذَرۡعُهَا سَبۡعُوۡنَ ذِرَاعًا فَاسۡلُكُوۡهُ ؕ‏","text_uthmani_tajweed":"ثُ<tajweed class=ghunnah>مّ</tajweed>َ فِى سِلْسِلَ<tajweed class=ikhafa>ةٍ ذ</tajweed>َرْعُهَا سَ<tajweed class=qalaqah>بْ</tajweed>عُونَ ذِرَا<tajweed class=ikhafa>عًا ف</tajweed>َ<tajweed class=ham_wasl>ٱ</tajweed>سْلُك<tajweed class=madda_permissible>ُو</tajweed>هُ <span class=end>٣٢</span>"},{"id":5356,"verse_key":"69:33","chapter_id":69,"verse_number":33,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"إِنَّهُۥ كَانَ لَا يُؤۡمِنُ بِٱللَّهِ ٱلۡعَظِيمِ ٣٣","text_indopak":"اِنَّهٗ كَانَ لَا يُؤۡمِنُ بِاللّٰهِ الۡعَظِيۡمِۙ‏","text_uthmani_tajweed":"إِ<tajweed class=ghunnah>نّ</tajweed>َهُ<tajweed class=madda_normal>ۥ</tajweed> كَانَ لَا يُؤْمِنُ بِ<tajweed class=ham_wasl>ٱ</tajweed>للَّهِ <tajweed class=ham_wasl>ٱ</tajweed>لْعَظ<tajweed class=madda_permissible>ِي</tajweed>مِ <span class=end>٣٣</span>"},{"id":5357,"verse_key":"69:34","chapter_id":69,"verse_number":34,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ ٣٤","text_indopak":"وَلَا يَحُضُّ عَلٰى طَعَامِ الۡمِسۡكِيۡنِؕ‏","text_uthmani_tajweed":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ <tajweed class=ham_wasl>ٱ</tajweed>لْمِسْك<tajweed class=madda_permissible>ِي</tajweed>نِ <span class=end>٣٤</span>"},{"id":5358,"verse_key":"69:35","chapter_id":69,"verse_number":35,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":568,"text_uthmani":"فَلَيۡسَ لَهُ ٱلۡيَوۡمَ هَٰهُنَا حَمِيمٞ ٣٥","text_indopak":"فَلَيۡسَ لَـهُ الۡيَوۡمَ هٰهُنَا حَمِيۡمٌۙ‏","text_uthmani_tajweed":"فَلَيْسَ لَهُ <tajweed class=ham_wasl>ٱ</tajweed>لْيَوْمَ هَ<tajweed class=madda_normal>ـٰ</tajweed>هُنَا حَم<tajweed class=madda_permissible>ِي</tajweed>مٌ <span class=end>٣٥</span>"},{"id":5359,"verse_key":"69:36","chapter_id":69,"verse_number":36,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":568,"text_uthmani":"وَلَا طَعَامٌ إِلَّا مِنۡ غِسۡلِينٖ ٣٦","text_indopak":"وَّلَا طَعَامٌ اِلَّا مِنۡ غِسۡلِيۡنٍۙ‏","text_uthmani_tajweed":"وَلَا طَعَامٌ إِلَّا مِنْ غِسْل<tajweed class=madda_permissible>ِي</tajweed>نٍ <span class=end>٣٦</span>"},{"id":5360,"verse_key":"69:37","chapter_id":69,"verse_number":37,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":568,"text_uthmani":"لَّا يَأۡكُلُهُۥٓ إِلَّا ٱلۡخَٰطِـُٔونَ ٣٧","text_indopak":"لَّا يَاۡكُلُهٗۤ اِلَّا الۡخٰطِئُوْنَ‏","text_uthmani_tajweed":"لَّا يَأْكُلُهُ<tajweed class=madda_obligatory>ۥٓ</tajweed> إِلَّا <tajweed class=ham_wasl>ٱ</tajweed>لْخَ<tajweed class=madda_normal>ـٰ</tajweed>طِــٔ<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٧</span>"},{"id":5361,"verse_key":"69:38","chapter_id":69,"verse_number":38,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":568,"text_uthmani":"فَلَآ أُقۡسِمُ بِمَا تُبۡصِرُونَ ٣٨","text_indopak":"فَلَاۤ اُقۡسِمُ بِمَا تُبۡصِرُوۡنَۙ‏","text_uthmani_tajweed":"فَل<tajweed class=madda_obligatory>َآ</tajweed> أُ<tajweed class=qalaqah>قْ</tajweed>سِمُ بِمَا تُ<tajweed class=qalaqah>بْ</tajweed>صِر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٨</span>"},{"id":5362,"verse_key":"69:39","chapter_id":69,"verse_number":39,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":568,"text_uthmani":"وَمَا لَا تُبۡصِرُونَ ٣٩","text_indopak":"وَمَا لَا تُبۡصِرُوۡنَۙ‏","text_uthmani_tajweed":"وَمَا لَا تُ<tajweed class=qalaqah>بْ</tajweed>صِر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٩</span>"},{"id":5363,"verse_key":"69:40","chapter_id":69,"verse_number":40,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":568,"text_uthmani":"إِنَّهُۥ لَقَوۡلُ رَسُولٖ كَرِيمٖ ٤٠","text_indopak":"اِنَّهٗ لَقَوۡلُ رَسُوۡلٍ كَرِيۡمٍۚ ۙ‏","text_uthmani_tajweed":"إِ<tajweed class=ghunnah>نّ</tajweed>َهُ<tajweed class=madda_normal>ۥ</ta