ed class=slnt>اْ</tajweed> بِ<tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>طَّاغِيَةِ <span class=end>٥</span>"},{"id":5329,"verse_key":"69:6","chapter_id":69,"verse_number":6,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":566,"text_uthmani":"وَأَمَّا عَادٞ فَأُهۡلِكُواْ بِرِيحٖ صَرۡصَرٍ عَاتِيَةٖ ٦","text_indopak":"وَاَمَّا عَادٌ فَاُهۡلِكُوۡا بِرِيۡحٍ صَرۡصَرٍ عَاتِيَةٍۙ‏","text_uthmani_tajweed":"وَأَ<tajweed class=ghunnah>مّ</tajweed>َا عَا<tajweed class=ikhafa>دٌ ف</tajweed>َأُهْلِكُو<tajweed class=slnt>اْ</tajweed> بِرِي<tajweed class=ikhafa>حٍ ص</tajweed>َرْصَرٍ عَاتِيَةٍ <span class=end>٦</span>"},{"id":5330,"verse_key":"69:7","chapter_id":69,"verse_number":7,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":566,"text_uthmani":"سَخَّرَهَا عَلَيۡهِمۡ سَبۡعَ لَيَالٖ وَثَمَٰنِيَةَ أَيَّامٍ حُسُومٗاۖ فَتَرَى ٱلۡقَوۡمَ فِيهَا صَرۡعَىٰ كَأَنَّهُمۡ أَعۡجَازُ نَخۡلٍ خَاوِيَةٖ ٧","text_indopak":"سَخَّرَهَا عَلَيۡهِمۡ سَبۡعَ لَيَالٍ وَّثَمٰنِيَةَ اَيَّامٍۙ حُسُوۡمًا ۙ فَتَرَى الۡقَوۡمَ فِيۡهَا صَرۡعٰىۙ كَاَنَّهُمۡ اَعۡجَازُ نَخۡلٍ خَاوِيَةٍ​ ۚ‏","text_uthmani_tajweed":"سَخَّرَهَا عَلَيْهِمْ سَ<tajweed class=qalaqah>بْ</tajweed>عَ لَيَا<tajweed class=idgham_ghunnah>لٍ و</tajweed>َثَمَ<tajweed class=madda_normal>ـٰ</tajweed>نِيَةَ أَيَّامٍ حُسُو<tajweed class=ikhafa>مًا ف</tajweed>َتَرَى <tajweed class=ham_wasl>ٱ</tajweed>لْقَوْمَ فِيهَا صَرْعَىٰ كَأَ<tajweed class=ghunnah>نّ</tajweed>َهُمْ أَعْجَازُ نَخْلٍ خَاوِيَةٍ <span class=end>٧</span>"},{"id":5331,"verse_key":"69:8","chapter_id":69,"verse_number":8,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":566,"text_uthmani":"فَهَلۡ تَرَىٰ لَهُم مِّنۢ بَاقِيَةٖ ٨","text_indopak":"فَهَلۡ تَرٰى لَهُمۡ مِّنۡۢ بَاقِيَةٍ‏","text_uthmani_tajweed":"فَهَلْ تَرَىٰ لَه<tajweed class=idgham_shafawi>ُم م</tajweed>ّ<tajweed class=iqlab>ِنۢ ب</tajweed>َاقِيَةٍ <span class=end>٨</span>"},{"id":5332,"verse_key":"69:9","chapter_id":69,"verse_number":9,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"وَجَآءَ فِرۡعَوۡنُ وَمَن قَبۡلَهُۥ وَٱلۡمُؤۡتَفِكَٰتُ بِٱلۡخَاطِئَةِ ٩","text_indopak":"وَجَآءَ فِرۡعَوۡنُ وَمَنۡ قَبۡلَهٗ وَالۡمُؤۡتَفِكٰتُ بِالۡخَـاطِئَةِ​ۚ‏","text_uthmani_tajweed":"وَج<tajweed class=madda_obligatory>َا</tajweed>ٓءَ فِرْعَوْنُ وَمَ<tajweed class=ikhafa>ن ق</tajweed>َ<tajweed class=qalaqah>بْ</tajweed>لَهُ<tajweed class=madda_normal>ۥ</tajweed> وَ<tajweed class=ham_wasl>ٱ</tajweed>لْمُؤْتَفِكَ<tajweed class=madda_normal>ـٰ</tajweed>تُ بِ<tajweed class=ham_wasl>ٱ</tajweed>لْخَاطِئَةِ <span class=end>٩</span>"},{"id":5333,"verse_key":"69:10","chapter_id":69,"verse_number":10,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"فَعَصَوۡاْ رَسُولَ رَبِّهِمۡ فَأَخَذَهُمۡ أَخۡذَةٗ رَّابِيَةً ١٠","text_indopak":"فَعَصَوۡا رَسُوۡلَ رَبِّهِمۡ فَاَخَذَهُمۡ اَخۡذَةً رَّابِيَةً‏","text_uthmani_tajweed":"فَعَصَوْ<tajweed class=slnt>اْ</tajweed> رَسُولَ رَبِّهِمْ فَأَخَذَهُمْ أَخْذَ<tajweed class=idgham_wo_ghunnah>ةً ر</tajweed>َّابِيَةً <span class=end>١٠</span>"},{"id":5334,"verse_key":"69:11","chapter_id":69,"verse_number":11,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"إِنَّا لَمَّا طَغَا ٱلۡمَآءُ حَمَلۡنَٰكُمۡ فِي ٱلۡجَارِيَةِ ١١","text_indopak":"اِنَّا لَمَّا طَغَا الۡمَآءُ حَمَلۡنٰكُمۡ فِى الۡجَارِيَةِ ۙ‏","text_uthmani_tajweed":"إِ<tajweed class=ghunnah>نّ</tajweed>َا لَ<tajweed class=ghunnah>مّ</tajweed>َا طَغَا <tajweed class=ham_wasl>ٱ</tajweed>لْم<tajweed class=madda_obligatory>َا</tajweed>ٓءُ حَمَلْنَ<tajweed class=madda_normal>ـٰ</tajweed>كُمْ فِى <tajweed class=ham_wasl>ٱ</tajweed>لْجَارِيَةِ <span class=end>١١</span>"},{"id":5335,"verse_key":"69:12","chapter_id":69,"verse_number":12,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":227,"page_number":567,"text_uthmani":"لِنَجۡعَلَهَا لَكُمۡ تَذۡكِرَةٗ وَتَعِيَهَآ أُذُنٞ وَٰعِيَةٞ ١٢","text_indopak":"لِن