ss=ham_wasl>ٱ</tajweed>لَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ يُحَافِظ<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٤</span>"},{"id":5410,"verse_key":"70:35","chapter_id":70,"verse_number":35,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":228,"page_number":569,"text_uthmani":"أُوْلَٰٓئِكَ فِي جَنَّٰتٖ مُّكۡرَمُونَ ٣٥","text_indopak":"اُولٰٓٮِٕكَ فِىۡ جَنّٰتٍ مُّكۡرَمُوۡنَؕ‏","text_uthmani_tajweed":"أُ<tajweed class=slnt>وْ</tajweed>لَ<tajweed class=madda_obligatory>ـٰٓ</tajweed>ئِكَ فِى جَ<tajweed class=ghunnah>نّ</tajweed>َ<tajweed class=madda_normal>ـٰ</tajweed><tajweed class=idgham_ghunnah>تٍ م</tajweed>ُّكْرَم<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٥</span>"},{"id":5411,"verse_key":"70:36","chapter_id":70,"verse_number":36,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":228,"page_number":569,"text_uthmani":"فَمَالِ ٱلَّذِينَ كَفَرُواْ قِبَلَكَ مُهۡطِعِينَ ٣٦","text_indopak":"فَمَالِ الَّذِيۡنَ كَفَرُوۡا قِبَلَكَ مُهۡطِعِيۡنَۙ‏","text_uthmani_tajweed":"فَمَالِ <tajweed class=ham_wasl>ٱ</tajweed>لَّذِينَ كَفَرُو<tajweed class=slnt>اْ</tajweed> قِبَلَكَ مُهْطِع<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٦</span>"},{"id":5412,"verse_key":"70:37","chapter_id":70,"verse_number":37,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":228,"page_number":569,"text_uthmani":"عَنِ ٱلۡيَمِينِ وَعَنِ ٱلشِّمَالِ عِزِينَ ٣٧","text_indopak":"عَنِ الۡيَمِيۡنِ وَعَنِ الشِّمَالِ عِزِيۡنَ‏","text_uthmani_tajweed":"عَنِ <tajweed class=ham_wasl>ٱ</tajweed>لْيَمِينِ وَعَنِ <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed>شِّمَالِ عِز<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٧</span>"},{"id":5413,"verse_key":"70:38","chapter_id":70,"verse_number":38,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":228,"page_number":569,"text_uthmani":"أَيَطۡمَعُ كُلُّ ٱمۡرِيٕٖ مِّنۡهُمۡ أَن يُدۡخَلَ جَنَّةَ نَعِيمٖ ٣٨","text_indopak":"اَيَطۡمَعُ كُلُّ امۡرِىءٍ مِّنۡهُمۡ اَنۡ ي