>ِّنْ عَذَابِ رَبِّه<tajweed class=idgham_shafawi>ِم م</tajweed>ُّشْفِق<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٧</span>"},{"id":5403,"verse_key":"70:28","chapter_id":70,"verse_number":28,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":228,"page_number":569,"text_uthmani":"إِنَّ عَذَابَ رَبِّهِمۡ غَيۡرُ مَأۡمُونٖ ٢٨","text_indopak":"اِنَّ عَذَابَ رَبِّهِمۡ غَيۡرُ مَاۡمُوۡنٍ‏","text_uthmani_tajweed":"إِ<tajweed class=ghunnah>نّ</tajweed>َ عَذَابَ رَبِّهِمْ غَيْرُ مَأْم<tajweed class=madda_permissible>ُو</tajweed>نٍ <span class=end>٢٨</span>"},{"id":5404,"verse_key":"70:29","chapter_id":70,"verse_number":29,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":228,"page_number":569,"text_uthmani":"وَٱلَّذِينَ هُمۡ لِفُرُوجِهِمۡ حَٰفِظُونَ ٢٩","text_indopak":"وَالَّذِيۡنَ هُمۡ لِفُرُوۡجِهِمۡ حٰفِظُوۡنَۙ‏","text_uthmani_tajweed":"وَ<tajweed class=ham_wasl>ٱ</tajweed>لَّذِينَ هُمْ لِفُرُوجِهِمْ حَ<tajweed class=madda_normal>ـٰ</tajweed>فِظ<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢٩</span>"},{"id":5405,"verse_key":"70:30","chapter_id":70,"verse_number":30,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":228,"page_number":569,"text_uthmani":"إِلَّا عَلَىٰٓ أَزۡوَٰجِهِمۡ أَوۡ مَا مَلَكَتۡ أَيۡمَٰنُهُمۡ فَإِنَّهُمۡ غَيۡرُ مَلُومِينَ ٣٠","text_indopak":"اِلَّا عَلٰٓى اَزۡوَاجِهِمۡ اَوۡ مَا مَلَـكَتۡ اَيۡمَانُهُمۡ فَاِنَّهُمۡ غَيۡرُ مَلُوۡمِيۡنَ​ۚ‏","text_uthmani_tajweed":"إِلَّا عَلَ<tajweed class=madda_obligatory>ىٰٓ</tajweed> أَزْو<tajweed class=madda_normal>َٲ</tajweed>جِهِمْ أَوْ مَا مَلَكَتْ أَيْمَ<tajweed class=madda_normal>ـٰ</tajweed>نُهُمْ فَإِ<tajweed class=ghunnah>نّ</tajweed>َهُمْ غَيْرُ مَلُوم<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٠</span>"},{"id":5406,"verse_key":"70:31","chapter_id":70,"verse_number":31,"juz_number":29,"hizb_number":57,"rub_el_hizb_number":228,"page_number":569,"text_uthmani":"فَمَنِ ٱبۡتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُوْلَٰٓئِكَ هُمُ ٱلۡعَادُونَ ٣١","text_indopak":"