i_tajweed":"وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣٦</span>"},{"id":5659,"verse_key":"77:37","chapter_id":77,"verse_number":37,"juz_number":29,"hizb_number":58,"rub_el_hizb_number":232,"page_number":581,"text_uthmani":"وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ٣٧","text_indopak":"وَيۡلٌ يَّوۡمَٮِٕذٍ لِّلۡمُكَذِّبِيۡنَ‏","text_uthmani_tajweed":"وَيْ<tajweed class=idgham_ghunnah>لٌ ي</tajweed>َوْمَئِ<tajweed class=idgham_wo_ghunnah>ذٍ ل</tajweed>ِّلْمُكَذِّب<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٧</span>"},{"id":5660,"verse_key":"77:38","chapter_id":77,"verse_number":38,"juz_number":29,"hizb_number":58,"rub_el_hizb_number":232,"page_number":581,"text_uthmani":"هَٰذَا يَوۡمُ ٱلۡفَصۡلِۖ جَمَعۡنَٰكُمۡ وَٱلۡأَوَّلِينَ ٣٨","text_indopak":"هٰذَا يَوۡمُ الۡفَصۡلِ​ۚ جَمَعۡنٰكُمۡ وَالۡاَوَّلِيۡنَ‏","text_uthmani_tajweed":"هَ<tajweed class=madda_normal>ـٰ</tajweed>ذَا يَوْمُ <tajweed class=ham_wasl>ٱ</tajweed>لْفَصْلِ‌ۖ جَمَعْنَ<tajweed class=madda_normal>ـٰ</tajweed>كُمْ وَ<tajweed class=ham_wasl>ٱ</tajweed>لْأَوَّل<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٣٨</span>"},{"id":5661,"verse_key":"77:39","chapter_id":77,"verse_number":39,"juz_number":29,"hizb_number":58,"rub_el_hizb_number":232,"page_number":581,"text_uthmani":"فَإِن كَانَ لَكُمۡ كَيۡدٞ فَكِيدُونِ ٣٩","text_indopak":"فَاِنۡ كَانَ لَـكُمۡ كَيۡدٌ فَكِيۡدُوۡنِ‏","text_uthmani_tajweed":"فَإِ<tajweed class=ikhafa>ن ك</tajweed>َانَ لَكُمْ كَيْ<tajweed class=ikhafa>دٌ ف</tajweed>َكِيد<tajweed class=madda_permissible>ُو</tajweed>نِ <span class=end>٣٩</span>"},{"id":5662,"verse_key":"77:40","chapter_id":77,"verse_number":40,"juz_number":29,"hizb_number":58,"rub_el_hizb_number":232,"page_number":581,"text_uthmani":"وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ٤٠","text_indopak":"وَيۡلٌ يَّوۡمَٮِٕذٍ لِّلۡمُكَذِّبِيۡنَ‏","text_uthmani_tajweed":"وَيْ<tajweed class=idgham_ghunnah>لٌ ي</tajweed>َوْمَئِ<tajweed class=idgham_wo_ghunnah>ذٍ ل</tajweed>ِّلْمُكَذِّب<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>٤٠</span>"},{"id":5663,"verse_key":"77:41","chapter_id":77,"verse_number":41,"juz_number":29,"hizb_number":58,"rub_el_hizb_number":232,"page_number":581,"text_uthmani":"إِنَّ ٱلۡمُتَّقِينَ فِي ظِلَٰلٖ وَعُيُونٖ ٤١","text_indopak":"اِنَّ الۡمُتَّقِيۡنَ فِىۡ ظِلٰلٍ وَّعُيُوۡنٍۙ‏","text_uthmani_tajweed":"إِ<tajweed class=ghunnah>نّ</tajweed>َ <tajweed class=ham_wasl>ٱ</tajweed>لْمُتَّقِينَ فِى ظِلَ<tajweed class=madda_normal>ـٰ</tajweed><tajweed class=idgham_ghunnah>لٍ و</tajweed>َعُي<tajweed class=madda_permissible>ُو</tajweed>نٍ <span class=end>٤١</span>"},{"id":5664,"verse_key":"77:42","chapter_id":77,"verse_number":42,"juz_number":29,"hizb_number":58,"rub_el_hizb_number":232,"page_number":581,"text_uthmani":"وَفَوَٰكِهَ مِمَّا يَشۡتَهُونَ ٤٢","text_indopak":"وَّفَوَاكِهَ مِمَّا يَشۡتَهُوۡنَؕ‏","text_uthmani_tajweed":"وَفَو<tajweed class=madda_normal>َٲ</tajweed>كِهَ مِ<tajweed class=ghunnah>مّ</tajweed>َا يَشْتَه<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٤٢</span>"},{"id":5665,"verse_key":"77:43","chapter_id":77,"verse_number":43,"juz_number":29,"hizb_number":58,"rub_el_hizb_number":232,"page_number":581,"text_uthmani":"كُلُواْ وَٱشۡرَبُواْ هَنِيٓـَٔۢا بِمَا كُنتُمۡ تَعۡمَلُونَ ٤٣","text_indopak":"كُلُوۡا وَاشۡرَبُوۡا هَنِيْٓئًا ۢ بِمَا كُنۡتُمۡ تَعۡمَلُوۡنَ‏","text_uthmani_tajweed":"كُلُو<tajweed class=slnt>اْ</tajweed> وَ<tajweed class=ham_wasl>ٱ</tajweed>شْرَبُو<tajweed class=slnt>اْ</tajweed> هَنِ<tajweed class=madda_obligatory>يٓـ</tajweed>ـ<tajweed class=iqlab>ـَٔۢا ب</tajweed>ِمَا كُ<tajweed class=ikhafa>نت</tajweed>ُمْ تَعْمَل<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٤٣</span>"},{"id":5666,"verse_key":"77:44","chapter_id":77,"verse_number":44,"juz_number":29,"hizb_number":58,"rub_el_hizb_number":232,"page_number":581,"text_uthmani":"إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ ٤٤","text_indopak":"اِنَّا كَذٰلِكَ نَجۡزِى الۡمُحۡسِنِيۡنَ‏