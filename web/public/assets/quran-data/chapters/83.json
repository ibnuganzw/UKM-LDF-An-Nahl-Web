{"chapterNumber":83,"verses":[{"id":5849,"verse_key":"83:1","chapter_id":83,"verse_number":1,"juz_number":30,"hizb_number":59,"rub_el_hizb_number":235,"page_number":587,"text_uthmani":"وَيۡلٞ لِّلۡمُطَفِّفِينَ ١","text_indopak":"وَيۡلٌ لِّلۡمُطَفِّفِيۡنَۙ‏","text_uthmani_tajweed":"وَيْ<tajweed class=idgham_wo_ghunnah>لٌ ل</tajweed>ِّلْمُطَفِّف<tajweed class=madda_permissible>ِي</tajweed>نَ <span class=end>١</span>"},{"id":5850,"verse_key":"83:2","chapter_id":83,"verse_number":2,"juz_number":30,"hizb_number":59,"rub_el_hizb_number":235,"page_number":587,"text_uthmani":"ٱلَّذِينَ إِذَا ٱكۡتَالُواْ عَلَى ٱلنَّاسِ يَسۡتَوۡفُونَ ٢","text_indopak":"الَّذِيۡنَ اِذَا اكۡتَالُوۡا عَلَى النَّاسِ يَسۡتَوۡفُوۡنَۖ‏","text_uthmani_tajweed":"ٱلَّذِينَ إِذَا <tajweed class=ham_wasl>ٱ</tajweed>كْتَالُو<tajweed class=slnt>اْ</tajweed> عَلَى <tajweed class=ham_wasl>ٱ</tajweed><tajweed class=laam_shamsiyah>ل</tajweed><tajweed class=ghunnah>نّ</tajweed>َاسِ يَسْتَوْف<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٢</span>"},{"id":5851,"verse_key":"83:3","chapter_id":83,"verse_number":3,"juz_number":30,"hizb_number":59,"rub_el_hizb_number":235,"page_number":587,"text_uthmani":"وَإِذَا كَالُوهُمۡ أَو وَّزَنُوهُمۡ يُخۡسِرُونَ ٣","text_indopak":"وَاِذَا كَالُوۡهُمۡ اَوْ وَّزَنُوۡهُمۡ يُخۡسِرُوۡنَؕ‏","text_uthmani_tajweed":"وَإِذَا كَالُوهُمْ أَو وَّزَنُوهُمْ يُخْسِر<tajweed class=madda_permissible>ُو</tajweed>نَ <span class=end>٣</span>"},{"id":5852,"verse_key":"83:4","chapter_id":83,"verse_number":4,"juz_number":30,"hizb_number":59,"rub_el_hizb_number":235,"page_number":587,"text_uthmani":"أَلَا يَظُنُّ أُوْلَٰٓئِكَ أَنَّهُم مَّبۡعُوثُونَ ٤","text_indopak":"اَلَا يَظُنُّ اُولٰٓٮِٕكَ اَنَّهُمۡ مَّبۡعُوۡثُوۡنَۙ‏","text_uthmani_tajweed":"أَلَا يَظُ<tajweed class=ghunnah>نّ</tajweed>ُ أُ<tajweed class=slnt>وْ</tajweed>لَ<tajweed class=madda_obligatory>ـٰٓ</tajweed>ئِكَ أَ<tajweed class=ghunnah>نّ</tajweed>َه<tajweed class=idgham_shafawi>ُم م</tajweed>َّ<tajweed class=qalaqah>ب