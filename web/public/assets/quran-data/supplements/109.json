{"chapterNumber":109,"verses":[{"verse_number":1,"translation_id":"Katakanlah: \"Hai orang-orang kafir,","transliteration":"Qul yaa-ai yuhal kaafiroon"},{"verse_number":2,"translation_id":"Aku tidak akan menyembah apa yang kamu sembah.","transliteration":"Laa a'budu ma t'abudoon"},{"verse_number":3,"translation_id":"Dan kamu bukan penyembah Tuhan yang aku sembah.","transliteration":"Wa laa antum 'aabidoona maa a'bud"},{"verse_number":4,"translation_id":"Dan aku tidak pernah menjadi penyembah apa yang kamu sembah,","transliteration":"Wa laa ana 'abidum maa 'abattum"},{"verse_number":5,"translation_id":"dan kamu tidak pernah (pula) menjadi penyembah Tuhan yang aku sembah.","transliteration":"Wa laa antum 'aabidoona ma a'bud"},{"verse_number":6,"translation_id":"Untukmu agamamu, dan untukkulah, agamaku\".","transliteration":"Lakum deenukum wa liya deen."}],"translationSource":"cache","transliterationSource":"cache"}