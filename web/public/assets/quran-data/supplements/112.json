{"chapterNumber":112,"verses":[{"verse_number":1,"translation_id":"Katakanlah: \"Dialah Allah, Yang Maha Esa.","transliteration":"Qul huwal laahu ahad"},{"verse_number":2,"translation_id":"Allah adalah Tuhan yang bergantung kepada-Nya segala sesuatu.","transliteration":"Allah hus-samad"},{"verse_number":3,"translation_id":"Dia tiada beranak dan tidak pula diperanakkan,","transliteration":"Lam yalid wa lam yoolad"},{"verse_number":4,"translation_id":"dan tidak ada seorangpun yang setara dengan Dia\".","transliteration":"Wa lam yakul-lahu kufuwan ahad"}],"translationSource":"cache","transliterationSource":"cache"}